{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "layout": {
      "contentSize": "880px",
      "wideSize": "1280px"
    },
    "color": {
      "defaultPalette": false,
      "defaultGradients": false,
      "defaultDuotone": false,
      "custom": true,
      "customGradient": true,
      "palette": [
        {
          "slug": "copper",
          "name": "Copper",
          "color": "#B87333"
        },
        {
          "slug": "copper-deep",
          "name": "Copper Deep",
          "color": "#8E4F1F"
        },
        {
          "slug": "copper-soft",
          "name": "Copper Soft",
          "color": "#D49866"
        },
        {
          "slug": "aubergine",
          "name": "Aubergine",
          "color": "#3D1E2A"
        },
        {
          "slug": "aubergine-deep",
          "name": "Aubergine Deep",
          "color": "#23121A"
        },
        {
          "slug": "rose-tan",
          "name": "Rose Tan",
          "color": "#E7C8B0"
        },
        {
          "slug": "rose-tan-soft",
          "name": "Rose Tan Soft",
          "color": "#F0D9C5"
        },
        {
          "slug": "background",
          "name": "Background",
          "color": "#F4EBDF"
        },
        {
          "slug": "background-warm",
          "name": "Background Warm",
          "color": "#EFE2D2"
        },
        {
          "slug": "surface",
          "name": "Surface",
          "color": "#FBF5EA"
        },
        {
          "slug": "surface-2",
          "name": "Surface 2",
          "color": "#F9EEDF"
        },
        {
          "slug": "text",
          "name": "Text",
          "color": "#2A1218"
        },
        {
          "slug": "text-muted",
          "name": "Text Muted",
          "color": "#5A3A40"
        },
        {
          "slug": "cream",
          "name": "Cream",
          "color": "#F0E5D6"
        }
      ],
      "gradients": [
        {
          "slug": "button-primary",
          "name": "Button Primary",
          "gradient": "linear-gradient(180deg, #B87333 0%, #8E4F1F 100%)"
        },
        {
          "slug": "brand-bar",
          "name": "Brand Bar",
          "gradient": "linear-gradient(180deg, #FBF5EA 0%, #F9EEDF 100%)"
        },
        {
          "slug": "footer",
          "name": "Footer",
          "gradient": "linear-gradient(180deg, #F9EEDF 0%, #FBF5EA 100%)"
        },
        {
          "slug": "dark",
          "name": "Dark",
          "gradient": "linear-gradient(180deg, #3D1E2A 0%, #23121A 100%)"
        }
      ]
    },
    "typography": {
      "fluid": false,
      "customFontSize": true,
      "fontFamilies": [
        {
          "slug": "fraunces",
          "name": "Fraunces",
          "fontFamily": "Fraunces, ui-serif, Georgia, serif"
        },
        {
          "slug": "mulish",
          "name": "Mulish",
          "fontFamily": "Mulish, system-ui, -apple-system, sans-serif"
        }
      ],
      "fontSizes": [
        {
          "slug": "x-small",
          "name": "X Small",
          "size": "11px"
        },
        {
          "slug": "xx-small",
          "name": "XX Small",
          "size": "12px"
        },
        {
          "slug": "small-minus",
          "name": "Small Minus",
          "size": "13px"
        },
        {
          "slug": "small",
          "name": "Small",
          "size": "14px"
        },
        {
          "slug": "medium-small",
          "name": "Medium Small",
          "size": "15px"
        },
        {
          "slug": "medium",
          "name": "Medium",
          "size": "17px"
        },
        {
          "slug": "large-small",
          "name": "Large Small",
          "size": "18px"
        },
        {
          "slug": "large",
          "name": "Large",
          "size": "22px"
        },
        {
          "slug": "large-plus",
          "name": "Large Plus",
          "size": "24px"
        },
        {
          "slug": "x-large",
          "name": "X Large",
          "size": "32px"
        },
        {
          "slug": "xx-large",
          "name": "XX Large",
          "size": "44px"
        },
        {
          "slug": "display-small",
          "name": "Display Small",
          "size": "clamp(34px, 3.4vw, 44px)"
        },
        {
          "slug": "display",
          "name": "Display",
          "size": "clamp(44px, 5.2vw, 68px)"
        }
      ]
    },
    "spacing": {
      "units": [
        "px",
        "em",
        "rem",
        "%",
        "vw",
        "vh"
      ],
      "padding": true,
      "margin": true,
      "blockGap": true,
      "spacingScale": {
        "steps": 1
      },
      "spacingSizes": [
        {
          "slug": "10",
          "name": "1",
          "size": "4px"
        },
        {
          "slug": "20",
          "name": "2",
          "size": "8px"
        },
        {
          "slug": "30",
          "name": "3",
          "size": "14px"
        },
        {
          "slug": "40",
          "name": "4",
          "size": "22px"
        },
        {
          "slug": "50",
          "name": "5",
          "size": "32px"
        },
        {
          "slug": "60",
          "name": "6",
          "size": "56px"
        },
        {
          "slug": "70",
          "name": "7",
          "size": "72px"
        }
      ]
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--background)",
      "text": "var(--wp--preset--color--text)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--mulish)",
      "fontSize": "var(--wp--preset--font-size--medium)",
      "lineHeight": "1.65"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--fraunces)",
          "fontWeight": "400",
          "lineHeight": "1.1",
          "letterSpacing": "-0.01em"
        },
        "color": {
          "text": "var(--wp--preset--color--text)"
        }
      },
      "h1": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--display)",
          "lineHeight": "1.04",
          "letterSpacing": "-0.015em"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--display-small)",
          "lineHeight": "1.08"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--large)",
          "lineHeight": "1.2",
          "fontWeight": "500"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--large-small)",
          "lineHeight": "1.2",
          "fontWeight": "500"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--copper-deep)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--aubergine)"
          }
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--gradient--button-primary)",
          "text": "var(--wp--preset--color--surface)"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--mulish)",
          "fontSize": "var(--wp--preset--font-size--small)",
          "fontWeight": "600",
          "letterSpacing": "0.08em",
          "textTransform": "uppercase"
        },
        "border": {
          "radius": "999px"
        },
        "spacing": {
          "padding": {
            "top": "16px",
            "right": "32px",
            "bottom": "16px",
            "left": "32px"
          }
        }
      }
    },
    "blocks": {
      "core/button": {
        "border": {
          "radius": "999px"
        }
      },
      "core/site-title": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--fraunces)",
          "fontWeight": "500"
        }
      }
    }
  },
  "templateParts": [
    {
      "name": "topbar",
      "title": "Top Bar",
      "area": "header"
    },
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    },
    {
      "name": "page-title",
      "title": "Page Title",
      "area": "uncategorized"
    },
    {
      "name": "embellishments",
      "title": "Embellishments",
      "area": "uncategorized"
    }
  ],
  "customTemplates": [
    {
      "name": "page",
      "title": "Page",
      "postTypes": [
        "page"
      ]
    },
    {
      "name": "front-page",
      "title": "Front Page",
      "postTypes": [
        "page"
      ]
    }
  ]
}